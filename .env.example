# 复制本文件为 .env 并填入你自己的密钥（.env 已被 .gitignore 忽略，不会提交）
# 兼容 OpenAI 接口的任意服务都可以；下面以 DeepSeek 为例。

OPENAI_API_KEY=你的密钥填这里
# 使用官方 OpenAI 时可删除/留空下面这行；使用 DeepSeek/代理时填对应 base_url
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 抓取 YouTube 字幕走的代理(国内必需)，按你的客户端端口/协议填：
#   socks5://127.0.0.1:10808 / http://127.0.0.1:10809 / http://127.0.0.1:7890
# 直连可访问 YouTube 则删除或留空。
YOUTUBE_PROXY=socks5://127.0.0.1:10808

# yt-dlp 读取浏览器登录态（与「油管视频下载」脚本一致时推荐 firefox）
# 先在对应浏览器里登录 YouTube，再填 firefox / edge / chrome 之一。
YOUTUBE_COOKIES_FROM_BROWSER=firefox

# YouTube 挑战求解：需本机安装 Node.js；首次会从 GitHub 拉取 ejs 组件
YOUTUBE_REMOTE_COMPONENTS=ejs:github
# YOUTUBE_NODE_PATH=C:\Program Files\nodejs\node.exe

# --- 可选：下载 YouTube 原视频（默认关闭）---
# 注意：下载大文件可能较慢、占用磁盘，且需自行确保符合当地法律与平台规则。
ENABLE_YOUTUBE_VIDEO_DOWNLOAD=0
# 下载格式选择器（yt-dlp format）。默认：优先最佳视频+音频，否则回退 best
# YOUTUBE_VIDEO_FORMAT=bv*+ba/b

# 也可以改用 cookies.txt 文件；若使用浏览器读取方式，此项留空即可。
# YOUTUBE_COOKIE_FILE=C:\path\to\cookies.txt

# --- Agent 防死循环参数（可选，留默认即可）---
# 单次请求 “思考->调用工具” 的最大轮数
AGENT_MAX_ITERATIONS=5
# 单次请求最长执行时间(秒)，超时强制结束
AGENT_MAX_EXECUTION_TIME=60

# YouTube 字幕分块翻译时（页面流式预览模式），每块大约多少字符
YOUTUBE_TRANSLATE_CHUNK_CHARS=1800

# 生成可下载 SRT / 翻译字幕文件时，一次交给 Agent 多少行字幕（保持行与时间轴一一对应）
TRANSLATE_BATCH_SIZE=20

# 导出 SRT 时：超长字幕按 。！？ 等标点拆条，并在到下一条开始前的空隙内按字数比例分配时间
SRT_SPLIT_LONG_CUES=1
# 至少多少字才尝试拆条
SRT_SPLIT_MIN_CHARS=30
# 本条官方结束时间与下一条开始相差超过该秒数时，把时间铺到下一条开始
SRT_SPLIT_MIN_GAP_SEC=1.5
# 拆条后每段最短显示时长(秒)
SRT_SPLIT_MIN_PART_DURATION=0.8

# 注入翻译 prompt 的视频简介最大字符数（过长会占满上下文）
YOUTUBE_CONTEXT_MAX_CHARS=1000
